# Local DB/Redis: run `pnpm docker:up` (see docker-compose.yml), then `pnpm db:migrate` and `pnpm seed`.
DATABASE_URL=postgresql://ubuntu:devpass@localhost:5433/teetimes
REDIS_URL=redis://localhost:6379
RESEND_API_KEY=
NEXTAUTH_SECRET=dev-secret-change-in-production
# API signs session JWTs with JWT_SECRET or NEXTAUTH_SECRET (same value in dev)
JWT_SECRET=dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Express API URL. For Vercel + Railway: set both to your public API origin (https://…), no trailing slash.
# API_URL — server-side (Next SSR, Route Handlers). NEXT_PUBLIC_API_URL — same value, for browser/client fetches.
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
PORT=3001

# Public booking UI: Google Maps JS + Places Autocomplete (browser). Use same key as GOOGLE_API_KEY or a restricted Maps key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_API_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
