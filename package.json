{
  "name": "teetimes",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "seed": "tsx packages/db/src/seed.ts",
    "seed:bookings": "tsx packages/db/src/seedBookings.ts",
    "seed:reset": "pnpm seed && pnpm seed:bookings",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "drizzle-kit": "^0.30.0"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild", "msgpackr-extract", "unrs-resolver"]
  }
}
